{
  "说明": "声明式工具定义 — 写JSON即可加新工具，无需写Python代码",
  "版本": "1.0",
  "工具列表": [
    {
      "名称": "查天气",
      "描述": "查询指定城市的天气",
      "类型": "http",
      "配置": {
        "URL": "https://wttr.in/${城市}?format=%C+%t+%w+%h",
        "方法": "GET",
        "请求头": {
          "User-Agent": "curl/7.68.0"
        },
        "响应处理": {
          "提取方法": "直接输出",
          "最大长度": 500
        }
      },
      "参数": [
        {
          "名称": "城市",
          "类型": "字符串",
          "必填": true,
          "说明": "城市名，如 beijing/shanghai/london"
        }
      ],
      "参数映射": {
        "城市": "城市"
      }
    },
    {
      "名称": "查IP",
      "描述": "查询IP地址的地理位置信息",
      "类型": "http",
      "配置": {
        "URL": "http://ip-api.com/json/${IP地址}?lang=zh-CN",
        "方法": "GET",
        "响应处理": {
          "提取方法": "JSON解析",
          "输出字段": ["country", "regionName", "city", "isp", "org", "as", "query"]
        }
      },
      "参数": [
        {
          "名称": "IP地址",
          "类型": "字符串",
          "必填": true,
          "说明": "IP地址，如 8.8.8.8"
        }
      ],
      "参数映射": {
        "IP地址": "IP地址"
      }
    },
    {
      "名称": "汇率查询",
      "描述": "查询两种货币之间的汇率",
      "类型": "http",
      "配置": {
        "URL": "https://api.exchangerate-api.com/v4/latest/${基础货币}",
        "方法": "GET",
        "响应处理": {
          "提取方法": "JSON路径",
          "路径": "$.rates.${目标货币}",
          "输出说明": "返回 {基础货币}→{目标货币} 的汇率"
        }
      },
      "参数": [
        {
          "名称": "基础货币",
          "类型": "字符串",
          "必填": true,
          "说明": "基础货币代码，如 USD/CNY/EUR"
        },
        {
          "名称": "目标货币",
          "类型": "字符串",
          "必填": true,
          "说明": "目标货币代码，如 CNY/USD/JPY"
        }
      ],
      "参数映射": {
        "基础货币": "基础货币",
        "目标货币": "目标货币"
      }
    },
    {
      "名称": "普通话",
      "描述": "朗读指定的文本内容（调用Windows内置语音合成）",
      "类型": "python",
      "配置": {
        "脚本": "import subprocess, tempfile, os\n文本 = '''${文本}'''\n干净文本 = 文本.replace('\\r', '').replace('\\n', '。')\nif len(干净文本) > 3000:\n    干净文本 = 干净文本[:3000]\n临时文件 = os.path.join(tempfile.gettempdir(), 'zf3d_speak.txt')\nwith open(临时文件, 'w', encoding='utf-8') as f:\n    f.write(干净文本)\ncmd = f'powershell -Command \"Add-Type -AssemblyName System.Speech; $t = Get-Content -Path \\'{临时文件}\\' -Raw -Encoding UTF8; (New-Object System.Speech.Synthesis.SpeechSynthesizer).Speak($t)\"'\n结果 = subprocess.run(cmd, shell=True, timeout=120)\ntry:\n    os.remove(临时文件)\nexcept:\n    pass\nif 结果.returncode != 0:\n    print(f'朗读失败(退出码{结果.returncode})')\nelse:\n    print(f'已朗读: {干净文本[:50]}...' if len(干净文本) > 50 else f'已朗读: {干净文本}')",
        "超时秒数": 120
      },
      "参数": [
        {
          "名称": "文本",
          "类型": "字符串",
          "必填": true,
          "说明": "要朗读的文本内容"
        }
      ],
      "参数映射": {
        "文本": "文本"
      }
    },
    {
      "名称": "倒数日",
      "描述": "计算从今天到指定日期的天数",
      "类型": "python",
      "配置": {
        "脚本": "from datetime import date\ntoday = date.today()\ntarget = date(${年}, ${月}, ${日})\ndelta = (target - today).days\nif delta > 0:\n    print(f'距离目标日期还有 {delta} 天')\nelif delta < 0:\n    print(f'目标日期已过去 {abs(delta)} 天')\nelse:\n    print('就是今天！')"
      },
      "参数": [
        {
          "名称": "年",
          "类型": "整数",
          "必填": true,
          "说明": "目标年份"
        },
        {
          "名称": "月",
          "类型": "整数",
          "必填": true,
          "说明": "目标月份(1-12)"
        },
        {
          "名称": "日",
          "类型": "整数",
          "必填": true,
          "说明": "目标日期(1-31)"
        }
      ],
      "参数映射": {
        "年": "年",
        "月": "月",
        "日": "日"
      }
    },
    {
      "名称": "计算器",
      "描述": "执行数学计算表达式",
      "类型": "python",
      "配置": {
        "脚本": "result = safe_eval(${表达式})\nprint(f'= {result}')",
        "安全": "使用AST安全计算器，零eval注入风险"
      },
      "参数": [
        {
          "名称": "表达式",
          "类型": "字符串",
          "必填": true,
          "说明": "数学表达式，如 1+2*3/4"
        }
      ],
      "参数映射": {
        "表达式": "表达式"
      }
    }
  ]
}
