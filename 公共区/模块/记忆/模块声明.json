{
  "名称": "记忆",
  "版本": "1.0",
  "入口": "主程序.py",
  "说明": "全JSON事件制记忆系统，长上下文适应",
  "依赖": [],
  "钩子": ["收到消息", "话题切换", "定时清理"],
  "挂载文件": [
    {"路径": "./隐私区/我的记忆/记忆库.json", "权限": "读写", "清理时删除": false},
    {"路径": "./隐私区/我的记忆/用户画像.json", "权限": "读写", "清理时删除": false},
    {"路径": "./隐私区/我的记忆/摘要索引.json", "权限": "读写", "清理时删除": false}
  ],
  "配置模式": {
    "自动摘要": { "类型": "布尔", "默认值": true },
    "摘要触发轮数": { "类型": "整数", "默认值": 20 },
    "冗余清理": { "类型": "布尔", "默认值": true },
    "冗余阈值天": { "类型": "整数", "默认值": 30 },
    "分片大小阈值KB": { "类型": "整数", "默认值": 100 },
    "每片最大事件数": { "类型": "整数", "默认值": 50 }
  }
}
